---
// src/layouts/Layout.astro
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Personal site' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | AmirHossein Movahedi</title>
    <meta name="description" content={description} />
    <!-- <link rel="icon" type="image/svg+xml" href="/favicon.svg" /> -->
    <!-- No external fonts – system fonts only -->
  </head>
  <body>
    <nav class="navbar">
      <div class="container nav-container">
        <a href="/AmirHossein-Movahedi.github.io/" class="logo">AM</a>
        <ul class="nav-links">
          <li><a href="/AmirHossein-Movahedi.github.io" class:list={{ active: currentPath === '/AmirHossein-Movahedi.github.io' }}>Home</a></li>
          <li><a href="/AmirHossein-Movahedi.github.io/about" class:list={{ active: currentPath === '/AmirHossein-Movahedi.github.io/about/' || currentPath === '/AmirHossein-Movahedi.github.io/about' }}>About</a></li>
          <li><a href="/AmirHossein-Movahedi.github.io/note" class:list={{ active: currentPath === '/AmirHossein-Movahedi.github.io/note/' || currentPath === '/AmirHossein-Movahedi.github.io/note' }}>Note</a></li>
          <li><a href="/AmirHossein-Movahedi.github.io/project" class:list={{ active: currentPath === '/AmirHossein-Movahedi.github.io/project/' || currentPath === '/AmirHossein-Movahedi.github.io/project' }}>Project</a></li>
          <li><a href="/AmirHossein-Movahedi.github.io/outside" class:list={{ active: currentPath === '/AmirHossein-Movahedi.github.io/outside/' || currentPath === '/AmirHossein-Movahedi.github.io/outside' }}>Outside</a></li>
        </ul>
      </div>
    </nav>
    <main class="container">
      <slot />
    </main>
    <footer>
      <div class="container">
        © {new Date().getFullYear()} AmirHossein-Movahedi
      </div>
    </footer>
  </body>
</html>

