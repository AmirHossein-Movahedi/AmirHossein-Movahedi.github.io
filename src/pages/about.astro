---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About — AmirHossein Movahedi", seo={{
	title: "About AmirHossein Movahedi",
	description: "Learn about my background, interests in complex systems and neuroscience."
	}}>
	<main class="page">
		<!-- About Section -->
		<section class="card">
			<div class="card-header">
				<h2>👤 About Me</h2>
			</div>
			<div class="card-content">
				<p>
					I am AmirHossein Movahedi, born on March 31, 2002, in Isfahan — known as the "Half of the World" — one of the largest and most historic cities in Iran. Currently, I study physics at university, where I've maintained a strong academic record.
				</p>
				<p>
					I earned my bachelor's degree from Isfahan University of Technology, ranking 3rd among 60 students. This achievement earned me one of only five offers to pursue my master's degree at Sharif University of Technology, one of Iran's most prestigious institutions.
				</p>
				<h3>❤️ Passions & Hobbies</h3>
				<p>
					Beyond academics, I'm passionate about card games, which have deepened my understanding of probability theory and strategic thinking. Games serve as a bridge between theoretical mathematics and practical decision-making.
				</p>
				<p>
					I'm driven by curiosity about how systems work — from neural networks to financial markets. The intersection of mathematics, physics, and biology fascinates me, and I'm committed to contributing meaningful research in these domains.
				</p>
			</div>
			</div>
		


			<div class="interests-grid">
				<h3>🧠 Research Interests</h3>

				<div class="interest-item">
					<h3>Complex Systems</h3>
					<p>Understanding intricate networks and emergent behaviors in biological and physical systems.</p>
				</div>
				<div class="interest-item">
					<h3>Brain Modeling</h3>
					<p>My master's thesis focuses on computational models of the human brain and neural dynamics.</p>
				</div>
				<div class="interest-item">
					<h3>Time Series Analysis</h3>
					<p>Exploring temporal patterns and predictive modeling in complex datasets.</p>
				</div>
				<div class="interest-item">
					<h3>Probability Theory</h3>
					<p>Deep dive into the mathematical foundations of uncertainty and probabilistic reasoning.</p>
				</div>
			</div>
		</section>
		<!-- Skills Section -->
		<section class="card">
			<div class="card-header">
				<h2>💻 Technical Skills</h2>
			</div>
			<div class="skills-container">
				<div class="skill-item">
					<div class="skill-name">Python</div>
					<div class="skill-levels">
						<span class="level active"></span>
						<span class="level active"></span>
						<span class="level active"></span>
						<span class="level active"></span>
						<span class="level active"></span>
					</div>
				</div>
				<div class="skill-item">
					<div class="skill-name">R</div>
					<div class="skill-levels">
						<span class="level active"></span>
						<span class="level active"></span>
						<span class="level inactive"></span>
						<span class="level inactive"></span>
						<span class="level inactive"></span>
					</div>
				</div>
			</div>

			<div class="skill-item">
				<div class="skill-name"><br>Latex</div>
				<div class="skill-levels">
					<span class="level active"></span>
					<span class="level active"></span>
					<span class="level inactive"></span>
					<span class="level inactive"></span>
					<span class="level inactive"></span>
				</div>
			</div>
		</div>
		</section>


	</main>
</Layout>

<style>
	.page {
		padding: 60px 6vw 120px;
		display: grid;
		gap: 60px;
	}
	/* Card Sections */
	.card {
		background: rgba(15, 23, 42, 0.7);
		border: 1px solid rgba(255, 255, 255, 0.08);
		padding: 48px;
		border-radius: 24px;
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
		transition: transform 0.25s ease, box-shadow 0.25s ease, border 0.25s ease;
		position: relative;
		overflow: hidden;
	}

	.card:hover {
		transform: translateY(-8px);
		border: 1px solid  rgba(30, 58, 138, 0.3);;
		box-shadow:
			0 20px 50px rgba(0, 0, 0, 0.35),
			0 0 30px rgba(30, 58, 138, 0.15);
	}

	.card-header {
		margin-bottom: 32px;
		padding-bottom: 16px;
		border-bottom: 2px solid rgba(59, 130, 246, 0.2);
	}

	.card h2 {
		font-family: 'Space Grotesk', sans-serif;
		font-size: clamp(1.6rem, 3vw, 1.9rem);
		margin: 0;
		color:  #ffffff;
		letter-spacing: -0.02em;
		font-weight: 700;
	}

	.card-content {
		font-family: 'Inter', sans-serif;
		font-size: 1rem;
		line-height: 1.8;
		color: rgba(255, 255, 255, 0.7);
	}

	.card-content p {
		margin: 0 0 20px;
	}

	.card-content p:last-child {
		margin-bottom: 0;
	}
	.interests-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(600px, 1fr));
		gap: 24px;
	}

	.interest-item {
		background: linear-gradient(135deg, rgba(11, 229, 245, 0.08), rgba(59, 130, 246, 0.08));
		border: 1px solid rgba(11, 124, 245, 0.2);
		padding: 24px;
		border-radius: 16px;
		transition: all 0.25s ease;
		position: relative;
		overflow: hidden;
	}

	/* .interest-item::before {
		content: '';
		position: absolute;
		top: 0;
		left: -100%;
		width: 100%;
		height: 100%;
		background: linear-gradient(90deg, transparent, rgba(245, 158, 11, 0.15), transparent);
		transition: left 0.6s ease;
	} */

	/* .interest-item:hover {
		border-color:  #f59e0b;
		background: linear-gradient(135deg, rgba(245, 158, 11, 0.12), rgba(59, 130, 246, 0.12));
		transform: translateY(-4px);
		box-shadow: 0 12px 30px rgba(245, 158, 11, 0.1);
	} */
/* 
	.interest-item:hover::before {
		left: 100%;
	} */

	.interest-item h3 {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 1.1rem;
		font-weight: 700;
		color: #ffffff;
		margin: 0 0 12px;
		letter-spacing: -0.01em;
	}

	.interest-item p {
		font-family: 'Inter', sans-serif;
		font-size: 0.9rem;
		line-height: 1.6;
		color: rgba(255, 255, 255, 0.7);
		margin: 0;
	}

	/* Skills Section */
	.skills-container {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 32px;
	}

	.skill-item {
		display: flex;
		flex-direction: column;
		gap: 10px;
	}

	.skill-name {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 1.1rem;
		font-weight: 700;
		color:  #ffffff;
		letter-spacing: -0.01em;
	}

	.skill-levels {
		display: flex;
		gap: 8px;
		align-items: center;
	}

	.level {
		width: 32px;
		height: 32px;
		border-radius: 8px;
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		cursor: pointer;
		border: 1px solid rgba(255, 255, 255, 0.1);
	}

	.level.active {
		background: linear-gradient(135deg, #2562c4 0%, #0d2463 100%);
		box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
	}

	.level.inactive {
		background: rgba(30, 58, 138, 0.2);
		border-color: rgba(30, 58, 138, 0.3);
	}

	.level:hover.active {
		transform: scale(1.1);
		box-shadow: 0 6px 16px rgba(59, 130, 246, 0.5);
	}

	.level:hover.inactive {
		border-color: rgba(59, 130, 246, 0.4);
		background: rgba(30, 58, 138, 0.3);
	}

	/* Responsive */
	@media (max-width: 1024px) {
		.card {
			padding: 36px;
		}

		.education-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 768px) {
		.page {
			padding: 40px 6vw 80px;
			gap: 40px;
		}

		.hero-section {
			padding: 60px 0;
		}

		.hero-section h1 {
			font-size: 2rem;
		}

		.card {
			padding: 24px;
		}

		.card-header {
			margin-bottom: 24px;
		}

		.interests-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.card,
		.education-item,
		.education-item::before,
		.interest-item,
		.interest-item::before {
			transition: none;
			transform: none;
		}
	}
</style>