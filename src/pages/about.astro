<style>
	.page {
		padding: 40px 6vw 120px;
		display: grid;
		gap: 80px;
	}

	.section-heading h1 {
		font-family: var(--font-serif);
		font-size: clamp(2.6rem, 5vw, 3.4rem);
		margin: 0 0 12px;
	}

	.section-heading p {
		margin: 0;
		color: var(--ink-muted);
	}

	.about-card {
		margin-top: 28px;
		background: rgba(255, 255, 255, 0.85);
		border-radius: var(--radius);
		padding: 28px;
		border: 1px solid var(--line);
		display: grid;
		gap: 24px;
		box-shadow: 0 18px 40px rgba(16, 17, 20, 0.08);
	}

	.about-stats {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
		gap: 16px;
	}

	.about-stats h3 {
		margin: 0 0 6px;
		font-size: 1.4rem;
	}

	.about-stats p {
		margin: 0;
		color: var(--ink-muted);
		font-size: 0.9rem;
	}
</style>