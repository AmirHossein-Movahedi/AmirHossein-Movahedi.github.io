---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Project — AmirHossein Movahedi">
	<main class="page">
		<section class="section">
			<div class="section-heading">
				<h1>Project</h1>
				<p>Highlighted case studies and meaningful outcomes.</p>
			</div>
			<div class="grid">
				<article class="project">
					<h3>Telagram Bot</h3>
					<p>
						I create telegram Bot for the 10th computational physics confrance of physics
						society of iran. 
						<a href="mailto:Movahedi.amirhossein@gmail.com">(link)</a>
					</p>
					<div class="tags">
						<span>python</span>
						<span>linux</span>
					</div>
				</article>

				<article class="project">
					<h3>EEG channel</h3>
					<p>
						Work on the EEG channel data.
					</p>
					<div class="tags">
						<span>Next.js</span>
						<span>TypeScript</span>
						<span>Observability</span>
					</div>
			</div>
		</section>
	</main>
</Layout>



<style>
	.page {
		padding: 40px 6vw 120px;
		display: grid;
		gap: 80px;
	}

	.section-heading h1 {
		font-family: var(--font-serif);
		font-size: clamp(2.6rem, 5vw, 3.4rem);
		margin: 0 0 12px;
	}

	.section-heading p {
		margin: 0;
		color: var(--ink-muted);
	}

	.grid {
		margin-top: 28px;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
		gap: 20px;
	}

	.project {
		background: var(--card);
		border: 1px solid var(--line);
		padding: 24px;
		border-radius: 18px;
		box-shadow: 0 10px 30px rgba(16, 17, 20, 0.08);
		transition: transform 0.25s ease, box-shadow 0.25s ease;
	}

	.project:hover {
		transform: translateY(-6px);
		box-shadow: 0 16px 40px rgba(16, 17, 20, 0.14);
	}

	.project h3 {
		margin: 0 0 8px;
	}

	.tags {
		display: flex;
		gap: 8px;
		flex-wrap: wrap;
		margin-top: 16px;
	}

	.tags span {
		padding: 6px 12px;
		border-radius: 999px;
		background: #f7f3ed;
		font-size: 0.82rem;
	}
</style>