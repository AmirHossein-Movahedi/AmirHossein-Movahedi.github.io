<script is:inline>
	const viewerKey = 'resume_viewer_count';
	const clickKey = 'resume_click_count';

	const getNumber = (key) => Number.parseInt(localStorage.getItem(key) ?? '0', 10);
	const setNumber = (key, value) => localStorage.setItem(key, String(value));

	const viewerCountEl = document.getElementById('viewer-count');
	const clickCountEl = document.getElementById('click-count');
	const countButton = document.getElementById('count-btn');

	const viewerCount = getNumber(viewerKey) + 1;
	setNumber(viewerKey, viewerCount);
	if (viewerCountEl) viewerCountEl.textContent = String(viewerCount);

	const clickCount = getNumber(clickKey);
	if (clickCountEl) clickCountEl.textContent = String(clickCount);

	if (countButton) {
		countButton.addEventListener('click', () => {
			const nextCount = getNumber(clickKey) + 1;
			setNumber(clickKey, nextCount);
			if (clickCountEl) clickCountEl.textContent = String(nextCount);
		});
	}
</script>






<script is:inline>
	// ---------- TOY GRAPH: COLORFUL NODES, MOUSE ATTRACTION, NO TEXT ----------
	const canvas = document.getElementById('toyCanvas');
	const ctx = canvas.getContext('2d');

	function resizeCanvas() {
		const container = canvas.parentElement;
		const width = container.clientWidth;
		canvas.width = width;
		canvas.height = Math.min(600, width * 0.5);
	}
	resizeCanvas();
	window.addEventListener('resize', resizeCanvas);

	const NODE_COUNT = 24;
	let nodes = [];

	// Random edges (about 12% density)
	const edges = [];
	for (let i = 0; i < NODE_COUNT; i++) {
		for (let j = i+1; j < NODE_COUNT; j++) {
			if (Math.random() < 0.12) edges.push([i, j]);
		}
	}
	// Ensure node 0 is central
	for (let i = 1; i < 5; i++) {
		if (!edges.some(e => (e[0]==0 && e[1]==i) || (e[0]==i && e[1]==0))) {
			edges.push([0, i]);
		}
	}

	const nodeRadius = 5;

	function initNodes() {
		const w = canvas.width;
		const h = canvas.height;
		nodes = [];
		for (let i = 0; i < NODE_COUNT; i++) {
			nodes.push({
				x: 80 + Math.random() * (w - 160),
				y: 60 + Math.random() * (h - 120),
				vx: (Math.random() - 0.5) * 0.8,
				vy: (Math.random() - 0.5) * 0.8,
				// color: `hsl(${ (i * 25) % 360 }, 70%, 60%)`
				color:`rgb(100, 0, 0)`
			});
		}
	}

	let mouseX = canvas.width/2, mouseY = canvas.height/2;
	let mouseActive = false;

	canvas.addEventListener('mousemove', (e) => {
		const rect = canvas.getBoundingClientRect();
		const scaleX = canvas.width / rect.width;
		const scaleY = canvas.height / rect.height;
		mouseX = (e.clientX - rect.left) * scaleX;
		mouseY = (e.clientY - rect.top) * scaleY;
		mouseActive = true;
	});
	canvas.addEventListener('mouseleave', () => { mouseActive = false; });

	function applyForces() {
		const REPULSION = 400;
		const ATTRACTION = 0.02;
		const MOUSE_FORCE = 0.4;
		const DAMP = 0.94;
		const MAX_VEL = 3.5;

		for (let i = 0; i < nodes.length; i++) {
			let fx = 0, fy = 0;
			const n1 = nodes[i];

			// Repulsion
			for (let j = 0; j < nodes.length; j++) {
				if (i === j) continue;
				const n2 = nodes[j];
				const dx = n1.x - n2.x;
				const dy = n1.y - n2.y;
				const distSq = dx*dx + dy*dy + 0.5;
				const force = REPULSION / distSq;
				const angle = Math.atan2(dy, dx);
				fx += Math.cos(angle) * force;
				fy += Math.sin(angle) * force;
			}

			// Spring edges
			for (let e of edges) {
				let a = nodes[e[0]];
				let b = nodes[e[1]];
				let dx = a.x - b.x, dy = a.y - b.y;
				let dist = Math.hypot(dx, dy);
				let ideal = 130;
				let stretch = (dist - ideal) * ATTRACTION;
				let angle = Math.atan2(dy, dx);
				let strX = Math.cos(angle) * stretch;
				let strY = Math.sin(angle) * stretch;
				if (e[0] === i) { fx -= strX; fy -= strY; }
				if (e[1] === i) { fx += strX; fy += strY; }
			}

			// Mouse attraction
			if (mouseActive) {
				let dx = n1.x - mouseX;
				let dy = n1.y - mouseY;
				let dist = Math.hypot(dx, dy);
				if (dist < 180) {
					let angle = Math.atan2(dy, dx);
					let force = (180 - dist) / 180 * MOUSE_FORCE;
					fx += Math.cos(angle) * force;
					fy += Math.sin(angle) * force;
				}
			}

			n1.vx = (n1.vx + fx) * DAMP;
			n1.vy = (n1.vy + fy) * DAMP;
			let vMag = Math.hypot(n1.vx, n1.vy);
			if (vMag > MAX_VEL) {
				n1.vx = (n1.vx / vMag) * MAX_VEL;
				n1.vy = (n1.vy / vMag) * MAX_VEL;
			}
			n1.x += n1.vx;
			n1.y += n1.vy;

			const margin = nodeRadius + 8;
			if (n1.x < margin) { n1.x = margin; n1.vx *= -0.6; }
			if (n1.x > canvas.width - margin) { n1.x = canvas.width - margin; n1.vx *= -0.6; }
			if (n1.y < margin) { n1.y = margin; n1.vy *= -0.6; }
			if (n1.y > canvas.height - margin) { n1.y = canvas.height - margin; n1.vy *= -0.6; }
		}
	}

	function draw() {
		if (!ctx) return;
		ctx.clearRect(0, 0, canvas.width, canvas.height);

		// Draw edges
		for (let e of edges) {
			const a = nodes[e[0]];
			const b = nodes[e[1]];
			ctx.beginPath();
			ctx.moveTo(a.x, a.y);
			ctx.lineTo(b.x, b.y);
			ctx.strokeStyle = `rgba(1, 1, 1, 0.45)`;
			ctx.lineWidth = 2;
			ctx.shadowBlur = 5;
			// ctx.shadowColor = '#d96a3a';
			ctx.stroke();
		}
		ctx.shadowBlur = 0;

		// Draw colorful nodes
		for (let n of nodes) {
			ctx.beginPath();
			ctx.arc(n.x, n.y, nodeRadius, 0, Math.PI*2);
			ctx.fillStyle = n.color;
			ctx.shadowBlur = 10;
			// ctx.shadowColor = 'rgba(0,0,0,0.2)';
			ctx.fill();
			// Inner glow
			ctx.beginPath();
			ctx.arc(n.x, n.y, nodeRadius-2, 0, Math.PI*2);
			// ctx.fillStyle = 'rgba(255,255,200,0.3)';
			ctx.fill();
		}
		ctx.shadowBlur = 0;
	}

	function animate() {
		applyForces();
		draw();
		requestAnimationFrame(animate);
	}

	function setup() {
		resizeCanvas();
		initNodes();
		window.addEventListener('resize', () => {
			resizeCanvas();
			initNodes();
		});
		animate();
	}

	setup();
</script>