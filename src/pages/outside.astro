---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Outside — AmirHossein Movahedi", seo={{
	title: "Outside AmirHossein Movahedi",
	description: "Learn about my background, interests in complex systems and neuroscience."}}>
	<main class="page">
		<section class="card">
      <h1>Where to find me around the web, plus a few favorite links, books I've read, and photos from my adventures.</h1>

			<div class="card-header">
        <h2>📚 Books I've Read</h2>
			</div>

    <div class="books-container">
      <div class="book-item">
        <!-- <h3>Atomic Habits</h3>
        <div class="book-author">Author: James Clear</div>
        <p class="book-summary">Small changes, remarkable results. This book explains how tiny habits compound over time to create significant life transformations. Key takeaway: focus on systems, not goals.</p> -->
        <h3>بیگانه، سقوط، افسانه سزیف، مرگ شادمانه، طاعون</h3>
        <div class="book-author">Author:Albert Camus</div>
        <br>
        <h3>برادران کارامازوف، جنایات و مکافات، ابله، قمار باز</h3>
        <div class="book-author">Author:Fyodor Dostoevsky</div>
        <br>
        <h3>بوف کور، سه قطره خون، حاجی اقا، زنده به گور، سگ ولگرد</h3>
        <div class="book-author">Author:Sadegh Hedayat</div>
        <br>
        <h3>مسخ</h3>
        <div class="book-author">Author: Kafka</div>
        <br>
        <h3>چنین گفت زرتشت</h3>
        <div class="book-author">Author: Nietzsche</div>
      </div>
    </div>

      <div class="card-header">
        <h2>📸 Photos</h2>
      </div>

    <div class="photo-grid">
          <figure>
      <div class="photo-placeholder gradient-2">
        <img
          src="/parsa.png"
          alt="parsa"
          width="400"
          height="400"
        />
      </div>
      <figcaption>
        <strong>NY</strong>
        <span>by Parsa</span>
      </figcaption>
    </figure>
    <figure>
      <div class="photo-placeholder gradient-2">
        <img
          src="/parsa1.png"
          alt="Koroush"
          width="400"
          height="400"
        />
      </div>
      <figcaption>
        <strong>San Diego, California</strong>
        <span>by Koroush</span>
      </figcaption>
    </figure>

        <figure>
      <div class="photo-placeholder gradient-2">
        <img
          src="/z.jpg"
          alt="zahra"
          width="400"
          height="400"
        />
      </div>
      <figcaption>
        <strong></strong>
        <span></span>
        <!-- <span>by Zahra</span> -->
      </figcaption>
    </figure>
</div>
	</main>
</Layout>

<style>
	.page {
	padding: 60px 6vw 120px;
	display: grid;
	gap: 60px;
}


h1 {
    font-size: 1.5rem;
    background: linear-gradient(135deg, #6366f1 0%, #ec4899 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: 800;
    margin-bottom: 0.5rem;
    letter-spacing: -1px;
  }
.card {
		background: rgba(15, 23, 42, 0.7);
		border: 1px solid rgba(255, 255, 255, 0.08);
		padding: 48px;
		border-radius: 24px;
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
		transition: transform 0.25s ease, box-shadow 0.25s ease, border 0.25s ease;
		position: relative;
		overflow: hidden;
	}

	.card:hover {
		transform: translateY(-8px);
		border: 1px solid  rgba(30, 58, 138, 0.3);;
		box-shadow:
			0 20px 50px rgba(0, 0, 0, 0.35),
			0 0 30px rgba(30, 58, 138, 0.15);
	}
	.card-header {
		margin-bottom: 32px;
		padding-bottom: 16px;
		border-bottom: 2px solid rgba(59, 130, 246, 0.2);
	}

	.card h2 {
		font-family: 'Space Grotesk', sans-serif;
		font-size: clamp(1.6rem, 3vw, 1.9rem);
		margin: 0;
		color:  #ffffff;
		letter-spacing: -0.02em;
		font-weight: 700;
	}

	.card-content {
		font-family: 'Inter', sans-serif;
		font-size: 1rem;
		line-height: 1.8;
		color: rgba(255, 255, 255, 0.7);
	}
	.card-content p {
		margin: 0 0 20px;
	}

	.card-content p:last-child {
		margin-bottom: 0;
	}


  /* Books Section */
  .books-container {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .book-item {
    padding: 1.5rem;
		background: linear-gradient(135deg, rgba(11, 229, 245, 0.08), rgba(59, 130, 246, 0.08));
    border-radius: 12px;
		border: 1px solid rgba(11, 124, 245, 0.2);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
  }

  /* .book-item::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(245, 158, 11, 0.1), transparent);
    transition: left 0.5s ease;
  } */

  /* .book-item:hover {
    border-color: var(--tertiary-accent);
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.12), rgba(99, 102, 241, 0.12));
    box-shadow: 0 8px 24px rgba(245, 158, 11, 0.1);
    transform: translateY(-4px);
  } */

  .book-item:hover::before {
    left: 100%;
  }

  .book-item h3 {
    font-size: 1.3rem;
    font-weight: 700;
    margin: 0 0 0.5rem 0;
    color: var(--color-text);
  }

  .book-author {
    font-size: 0.95rem;
    color: var(--tertiary-accent);
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .book-summary {
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba(var(--color-text-rgb, 255, 255, 255), 0.8);
    margin: 0;
  }


  /* Photos Gallery */
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  figure {
    margin: 0;
    text-align: center;
  }

  .photo-placeholder {
    width: 100%;
    height: 240px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 4rem;
    position: relative;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: pointer;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

  .photo-placeholder::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: rgba(255, 255, 255, 0.15);
    transition: left 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
/* 
  figure:hover .photo-placeholder::before {
    left: 100%;
  } */

  figure:hover .photo-placeholder {
    transform: scale(1.08);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
  }

  figcaption {
    margin-top: 1rem;
    font-size: 0.95rem;
  }

  figcaption strong {
    display: block;
    color: #ffffff;
    font-weight: 700;
    margin-bottom: 0.3rem;
  }

  figcaption span {
    color: #6366f1;
    font-size: 0.85rem;
    font-weight: 500;
  }
</style>
