---
// src/pages/outside.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Outside">
  <h1>🌐 Outside</h1>
  <p>Where to find me around the web, plus a few favorite links and some book that I read and want to publish the
    summary of them.
  </p>

  <div class="card">
    <h2>🔗 Me elsewhere</h2>
    <ul style="margin-left: 1.25rem;">
      <li><a href="https://github.com/YOUR_USERNAME" target="_blank" rel="noopener">GitHub</a></li>
      <li><a href="https://twitter.com/YOUR_HANDLE" target="_blank" rel="noopener">Twitter / X</a></li>
      <li><a href="https://linkedin.com/in/YOUR_ID" target="_blank" rel="noopener">LinkedIn</a></li>
    </ul>
  </div>

  <div class="card">
    <h2>🧠 Recommended reads & tools</h2>
    <ul style="margin-left: 1.25rem;">
      <li><a href="https://astro.build" target="_blank" rel="noopener">Astro framework</a></li>
      <li><a href="https://github.com/pages" target="_blank" rel="noopener">GitHub Pages</a></li>
      <li><a href="https://developer.mozilla.org" target="_blank" rel="noopener">MDN Web Docs</a></li>
      <li><a href="https://overcast.fm" target="_blank" rel="noopener">Overcast (podcasts)</a></li>
    </ul>
  </div>
</Layout>